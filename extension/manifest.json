{
  "manifest_version": 3,
  "name": "FB AI Translator",
  "version": "1.1",
  "description": "Translate and reply Facebook messages with AI",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "http://localhost:3001/*",
    "https://www.facebook.com/*",
    "https://business.facebook.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://business.facebook.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}